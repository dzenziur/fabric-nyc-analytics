	measure 'Correlation Trips vs PM2.5' =
			
			VAR S =
			    SUMMARIZE(
			        DimDate,
			        DimDate[date_key],
			        "X", [Total Trips],
			        "Y", [Avg PM2.5]
			    )
			VAR F = FILTER(S, NOT ISBLANK([X]) && NOT ISBLANK([Y]))
			VAR n = COUNTROWS(F)
			VAR sX = SUMX(F, [X])
			VAR sY = SUMX(F, [Y])
			VAR sXY = SUMX(F, [X] * [Y])
			VAR sX2 = SUMX(F, [X] * [X])
			VAR sY2 = SUMX(F, [Y] * [Y])
			RETURN DIVIDE(
			    n * sXY - sX * sY,
			    SQRT((n * sX2 - sX * sX) * (n * sY2 - sY * sY))
			)
		formatString: 0.000
		lineageTag: b2f6a8a3-51e3-4b86-b877-4477cc0c3879

		changedProperty = Name

		changedProperty = FormatString

