	measure 'Avg Fare USD' = DIVIDE([Total Revenue USD], [Total Trips])
		lineageTag: 7e4624cc-c19f-4e2d-aafa-69cee8acc8d5

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Revenue as % of US GDP' =
			
			DIVIDE(
			    [Total Revenue USD],
			    CALCULATE(
			        MAX(DimGDP[gdp_usd]),
			        DimGDP[country_code] = "US",
			        DimGDP[year] = SELECTEDVALUE(DimDate[year])
			    )
			) * 100
		formatString: 0.000%;-0.000%;0.000%
		lineageTag: 720d5e53-f09c-474b-91e3-aeb54a694300

		changedProperty = Name

		changedProperty = FormatString

	measure 'Revenue USD YoY %' =
			
			VAR yr = SELECTEDVALUE(DimDate[year])
			VAR cur = [Total Revenue USD]
			VAR prev = CALCULATE(
			    [Total Revenue USD],
			    REMOVEFILTERS(DimDate),
			    DimDate[year] = yr - 1
			)
			RETURN IF(ISBLANK(yr), BLANK(), DIVIDE(cur - prev, prev))
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: 6f8aa723-e7cf-4456-923d-260bcdcb382c

		changedProperty = Name

		changedProperty = FormatString

	measure 'Revenue USD YoY Label' =
			
			VAR pct = [Revenue USD YoY %]
			VAR yr = SELECTEDVALUE(DimDate[year])
			RETURN
			IF(
			    ISBLANK(pct) || ISBLANK(yr),
			    BLANK(),
			    IF(pct >= 0, "▲ +", "▼ ") & FORMAT(pct, "0.0%") & " vs " & (yr - 1)
			)
		lineageTag: ce748d26-6589-4f1b-bb4d-7a82852d035b

		changedProperty = Name

