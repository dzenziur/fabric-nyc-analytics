# Environment variables for Fabric NYC Analytics
# Copy to .env and fill in your values. Never commit .env.

# Fabric SQL endpoint — Entra ID Service Principal auth
# Server: <workspace-id>.datawarehouse.fabric.microsoft.com (one host per workspace)
# Service Principal must be granted Read on silver_lakehouse SQL endpoint and gold_warehouse.
FABRIC_SQL_SERVER=your_workspace.datawarehouse.fabric.microsoft.com
FABRIC_SP_CLIENT_ID=your_service_principal_client_id
FABRIC_SP_CLIENT_SECRET=your_service_principal_client_secret
SILVER_LAKEHOUSE_DB=silver_lakehouse
GOLD_WAREHOUSE_DB=gold_warehouse

# InfluxDB OSS — weather time-series sink, runs as container in docker-compose
# URL points at the influxdb service inside the compose network.
# Token + org + bucket are auto-created on first boot via INFLUXDB_INIT_* vars below.
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=replace_with_a_long_random_token
INFLUXDB_ORG=nyc_analytics
INFLUXDB_BUCKET=weather_nyc

# InfluxDB initial bootstrap (consumed only by the influxdb container on first start)
INFLUXDB_INIT_USERNAME=admin
INFLUXDB_INIT_PASSWORD=replace_with_a_strong_password
INFLUXDB_INIT_MODE=setup

# Grafana — auto-provisioned datasource reads from InfluxDB above. Admin login for the UI.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace_with_a_strong_password
